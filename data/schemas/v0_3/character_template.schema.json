{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spritesplayground.local/schemas/v0_3/character_template.schema.json",
  "title": "CharacterTemplate",
  "type": "object",
  "additionalProperties": false,
  "propertyNames": {
    "not": {
      "enum": [
        "action",
        "actions",
        "attack",
        "base_action_set",
        "base_actions",
        "base_attack_moves",
        "cooldown_seconds",
        "duration_seconds",
        "seconds"
      ]
    }
  },
  "required": [
    "schema_version",
    "template_id",
    "sprite_set_ref",
    "hurtboxes",
    "foot_collision",
    "hp",
    "equipped_moves"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3"
    },
    "template_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "sprite_set_ref": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "hurtboxes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/rect"
      },
      "propertyNames": {
        "pattern": "^hurt_[a-z0-9_]+$"
      }
    },
    "foot_collision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "center",
        "radius"
      ],
      "properties": {
        "center": {
          "$ref": "#/$defs/vector2"
        },
        "radius": {
          "$ref": "#/$defs/vector2_positive"
        }
      }
    },
    "hp": {
      "type": "integer",
      "minimum": 1
    },
    "equipped_moves": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "contains": {
        "const": "idle"
      },
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  },
  "$defs": {
    "rect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "w",
        "h"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "w": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "h": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "vector2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        }
      }
    },
    "vector2_positive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "y": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    }
  }
}
