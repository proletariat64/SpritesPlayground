{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spritesplayground.local/schemas/v0_3/sprite_set.schema.json",
  "title": "SpriteSet",
  "type": "object",
  "additionalProperties": false,
  "propertyNames": {
    "not": {
      "enum": [
        "action",
        "actions",
        "attack",
        "base_action_set",
        "base_actions",
        "base_attack_moves",
        "cooldown_seconds",
        "duration_seconds",
        "seconds"
      ]
    }
  },
  "required": [
    "schema_version",
    "sprite_set_id",
    "animation_clips",
    "frame_sequences",
    "required_moves_mapping"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3"
    },
    "sprite_set_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "animation_clips": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/animation_clip"
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "frame_sequences": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "required_moves_mapping": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    }
  },
  "$defs": {
    "animation_clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clip_id",
        "frame_sequence_ref",
        "loop"
      ],
      "properties": {
        "clip_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "frame_sequence_ref": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "loop": {
          "type": "boolean"
        }
      }
    }
  }
}
